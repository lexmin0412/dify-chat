{
	"name": "dify-app-hub-root",
	"version": "0.8.0-beta.4",
	"private": true,
	"scripts": {
		"build": "pnpm -r build",
		"dev:app": "pnpm --filter dify-app-hub dev",
		"dev:docs": "pnpm --filter dify-app-hub-docs dev",
		"build:app": "pnpm --filter dify-app-hub build",
		"build:docs": "pnpm --filter dify-app-hub-docs build",
		"create-admin": "pnpm --filter dify-app-hub create-admin",
		"test": "pnpm -r test",
		"changeset": "changeset",
		"version-packages": "changeset version",
		"release": "echo 'Use: git tag vX.Y.Z && git push --tags (see .agents/skills/release/SKILL.md)'",
		"lint": "oxlint",
		"lint:fix": "oxlint --fix",
		"format": "oxfmt",
		"format:check": "oxfmt --check"
	},
	"devDependencies": {
		"@changesets/cli": "^2.29.7",
		"globals": "^17.6.0",
		"husky": "^9.1.7",
		"lint-staged": "^15.5.1",
		"oxfmt": "^0.23.0",
		"oxlint": "^1.38.0",
		"oxlint-tsgolint": "^0.10.1",
		"typescript": "^5.9.3"
	},
	"packageManager": "pnpm@10.8.1+sha512.c50088ba998c67b8ca8c99df8a5e02fd2ae2e2b29aaf238feaa9e124248d3f48f9fb6db2424949ff901cffbb5e0f0cc1ad6aedb602cd29450751d11c35023677"
}
